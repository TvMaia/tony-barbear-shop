---
const BOOKING_URL = 'https://tony9432.setmore.com/';
const MAPS_URL = 'https://maps.google.com/?q=2705+Centre+St+NW,+Calgary,+Alberta';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Angelo's & Luigi's Barbershop | Calgary's Most Trusted Barbers</title>
  <meta name="description" content="Calgary's most trusted barbershop. 770 five-star reviews. Haircuts, fades, beard trims, hot shaves. Book online at 2705 Centre St NW." />
  <link rel="canonical" href="https://tvmaia.github.io/tony-barbear-shop/" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%23080807'/%3E%3Ctext x='50%25' y='56%25' dominant-baseline='middle' text-anchor='middle' font-family='Georgia%2C serif' font-size='13' font-weight='bold' fill='%23c8a44a'%3EA%26L%3C/text%3E%3C/svg%3E" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Angelo's & Luigi's Barbershop | Calgary" />
  <meta property="og:description" content="Calgary's most trusted barbershop. 770 five-star reviews. Old-school craft, modern results." />
  <meta property="og:image" content="https://images.unsplash.com/photo-1580618672591-eb180b1a973f?w=1200&h=630&auto=format&fit=crop&q=85" />
  <meta property="og:url" content="https://tvmaia.github.io/tony-barbear-shop/" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Angelo's & Luigi's Barbershop | Calgary" />
  <meta name="twitter:description" content="770 five-star reviews. Old-school craft, modern results." />
  <meta name="twitter:image" content="https://images.unsplash.com/photo-1580618672591-eb180b1a973f?w=1200&h=630&auto=format&fit=crop&q=85" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    /* ── TOKENS ── */
    :root {
      --bg:       #080807;
      --bg2:      #111110;
      --bg3:      #181715;
      --gold:     #c8a44a;
      --gold-dim: rgba(200,164,74,0.18);
      --cream:    #f0e8d8;
      --muted:    #7a7060;
      --dim:      #3a3530;
      --border:   rgba(200,164,74,0.12);
      --ease:     cubic-bezier(0.25, 0.46, 0.45, 0.94);
      --display:  'Bebas Neue', Impact, sans-serif;
      --serif:    'Cormorant Garamond', Georgia, serif;
      --sans:     'DM Sans', system-ui, sans-serif;
      --max:      1120px;
    }

    /* ── RESET ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--cream);
      font-family: var(--sans);
      font-weight: 300;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    img { display: block; width: 100%; object-fit: cover; }
    a { color: inherit; text-decoration: none; }

    /* ── GRAIN OVERLAY ── */
    body::after {
      content: '';
      position: fixed; inset: 0; z-index: 9999;
      pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      opacity: 0.028;
    }

    /* ── LAYOUT ── */
    .container { max-width: var(--max); margin: 0 auto; padding: 0 2rem; }
    .sp { padding: 7rem 0; }
    .sp-sm { padding: 4rem 0; }

    /* ── PAGE LOADER ── */
    #loader {
      position: fixed; inset: 0;
      background: var(--bg);
      z-index: 99998;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 1.25rem;
      transition: opacity 0.7s var(--ease), visibility 0.7s;
    }
    #loader.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
    .loader-mf {
      font-family: var(--display);
      font-size: 5rem;
      color: var(--gold);
      letter-spacing: 0.12em;
      line-height: 1;
      animation: loaderFadeIn 0.9s var(--ease) both;
    }
    .loader-bar {
      width: 0; height: 1px;
      background: linear-gradient(to right, transparent, var(--gold), transparent);
      animation: loaderBar 0.8s var(--ease) 0.4s both;
    }
    .loader-label {
      font-size: 0.6rem; letter-spacing: 0.28em; text-transform: uppercase;
      color: var(--muted);
      opacity: 0;
      animation: loaderFadeIn 0.6s var(--ease) 0.6s both;
    }
    @keyframes loaderFadeIn {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes loaderBar { to { width: 72px; } }

    /* ── SCROLL PROGRESS ── */
    #progress {
      position: fixed; top: 0; left: 0;
      height: 2px; width: 0%;
      background: linear-gradient(to right, #8b6914, var(--gold), #f0d888);
      z-index: 99999;
      transition: width 0.08s linear;
    }

    /* ── CUSTOM CURSOR ── */
    @media (hover: hover) and (pointer: fine) {
      body { cursor: none; }
      a, button, [role="button"] { cursor: none; }
      .cursor {
        position: fixed;
        width: 32px; height: 32px;
        border: 1px solid rgba(200,164,74,0.5);
        border-radius: 50%;
        pointer-events: none; z-index: 99997;
        top: 0; left: 0;
        transition: width 0.3s var(--ease), height 0.3s var(--ease), background 0.3s, border-color 0.3s;
        will-change: transform;
      }
      .cursor.hovering {
        width: 50px; height: 50px;
        background: rgba(200,164,74,0.06);
        border-color: rgba(200,164,74,0.85);
      }
      .cursor-dot {
        position: fixed;
        width: 4px; height: 4px;
        background: var(--gold);
        border-radius: 50%;
        pointer-events: none; z-index: 99997;
        top: 0; left: 0;
        will-change: transform;
        transition: transform 0.04s;
      }
    }

    /* ── SCROLL ANIMATIONS ── */
    .fade-up { opacity: 0; transform: translateY(32px); transition: opacity 0.7s var(--ease), transform 0.7s var(--ease); }
    .fade-up.visible { opacity: 1; transform: translateY(0); }
    .fade-up.d1 { transition-delay: 0.1s; }
    .fade-up.d2 { transition-delay: 0.2s; }
    .fade-up.d3 { transition-delay: 0.3s; }
    .fade-up.d4 { transition-delay: 0.4s; }
    .fade-up.d5 { transition-delay: 0.5s; }

    /* ── TYPOGRAPHY ── */
    .display { font-family: var(--display); letter-spacing: 0.03em; line-height: 0.92; }
    .headline { font-family: var(--serif); font-weight: 600; line-height: 1.15; }
    .overline { font-size: 0.65rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); display: block; }
    .gold { color: var(--gold); }
    .muted { color: var(--muted); }

    /* ── BUTTONS ── */
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.9rem 2.25rem;
      font-family: var(--sans);
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.22s var(--ease);
      position: relative;
    }
    .btn-sm { padding: 0.55rem 1.25rem; font-size: 0.65rem; }
    .btn-lg { padding: 1.15rem 3rem; font-size: 0.8rem; }
    .btn-primary { background: var(--gold); color: #080807; }
    .btn-primary:hover { background: #dfc06a; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(200,164,74,0.25); }
    .btn-ghost {
      background: transparent; color: var(--cream);
      border: 1px solid rgba(240,232,216,0.25);
    }
    .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 500;
      padding: 1.5rem 0;
      background: rgba(8,8,7,0.88);
      backdrop-filter: blur(12px) saturate(120%);
      border-bottom: 1px solid var(--border);
      transition: padding 0.3s var(--ease);
    }
    nav.scrolled { padding: 1rem 0; }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: var(--display); font-size: 1.15rem; letter-spacing: 0.12em; }
    .nav-logo em { color: var(--gold); font-style: normal; }
    .nav-right { display: flex; align-items: center; gap: 2.5rem; }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a {
      font-size: 0.68rem; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--muted);
      transition: color 0.2s;
      position: relative;
    }
    .nav-links a::after {
      content: ''; position: absolute; bottom: -3px; left: 0;
      width: 0; height: 1px; background: var(--gold);
      transition: width 0.3s var(--ease);
    }
    .nav-links a:hover { color: var(--cream); }
    .nav-links a:hover::after { width: 100%; }

    .nav-hamburger {
      display: none; flex-direction: column; gap: 5px;
      cursor: pointer; padding: 4px; background: none; border: none;
    }
    .nav-hamburger span { display: block; width: 22px; height: 1px; background: var(--gold); transition: all 0.3s; }
    .nav-hamburger.active span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .nav-hamburger.active span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    .nav-hamburger.active span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

    @media (max-width: 768px) { .nav-links { display: none; } .nav-hamburger { display: flex; } }

    /* ── MOBILE MENU ── */
    .mobile-menu {
      position: fixed; inset: 0;
      background: var(--bg);
      z-index: 499;
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2.25rem;
      transform: translateX(100%);
      transition: transform 0.5s var(--ease);
    }
    .mobile-menu.open { transform: translateX(0); }
    .mobile-menu__close {
      position: absolute; top: 1.5rem; right: 1.5rem;
      width: 40px; height: 40px;
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      color: var(--gold); cursor: pointer; background: none;
      transition: background 0.3s;
    }
    .mobile-menu__close:hover { background: var(--gold-dim); }
    .mobile-menu a {
      font-family: var(--display); font-size: 2.4rem; letter-spacing: 0.06em;
      color: var(--cream); transition: color 0.25s;
    }
    .mobile-menu a:hover { color: var(--gold); }
    .mobile-menu__deco {
      position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
      font-size: 0.6rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--dim);
    }

    /* ── HERO ── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex; align-items: flex-end;
      padding-bottom: 6rem;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background-image: url('https://images.unsplash.com/photo-1580618672591-eb180b1a973f?w=1800&auto=format&fit=crop&q=85');
      background-size: cover; background-position: center 40%;
      filter: brightness(0.2) saturate(0.5);
      transform: scale(1.04);
      transition: transform 8s var(--ease);
    }
    .hero-bg.loaded { transform: scale(1); }
    .hero-gradient {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(8,8,7,0.97) 0%, rgba(8,8,7,0.45) 50%, rgba(8,8,7,0.15) 100%);
    }
    .hero-content {
      position: relative; z-index: 1;
      padding: 0 2rem;
      max-width: var(--max);
      margin: 0 auto;
      width: 100%;
    }
    .hero-tag {
      display: inline-flex; align-items: center; gap: 0.75rem;
      margin-bottom: 2rem;
    }
    .hero-tag-line { width: 2rem; height: 1px; background: var(--gold); }
    .hero-tag span { font-size: 0.65rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); }
    .hero-h1 {
      font-family: var(--display);
      font-size: clamp(4.5rem, 13vw, 11rem);
      letter-spacing: 0.02em;
      line-height: 0.88;
      margin-bottom: 2rem;
    }
    .hero-h1 .accent {
      font-family: var(--serif);
      font-style: italic;
      font-size: 0.65em;
      color: var(--gold);
      letter-spacing: 0;
      line-height: 1;
    }
    .hero-sub {
      font-size: 0.9rem;
      color: var(--muted);
      letter-spacing: 0.06em;
      margin-bottom: 2.5rem;
      max-width: 440px;
    }
    .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
    .hero-scroll-hint {
      position: absolute; right: 2rem; bottom: 4rem;
      writing-mode: vertical-rl;
      font-size: 0.6rem; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--dim); display: flex; align-items: center; gap: 0.75rem;
    }
    .hero-scroll-hint::after {
      content: ''; width: 1px; height: 3rem;
      background: linear-gradient(to bottom, var(--gold), transparent);
    }

    /* ── TRUST BAR ── */
    .trust {
      background: var(--bg2);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 1.25rem 0;
      overflow: hidden;
    }
    .trust-track {
      display: flex; align-items: center; gap: 5rem;
      white-space: nowrap;
      animation: trustMarquee 34s linear infinite;
      width: max-content;
    }
    .trust:hover .trust-track { animation-play-state: paused; }
    @keyframes trustMarquee {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    .trust-item { display: flex; align-items: center; gap: 1rem; flex-shrink: 0; }
    .trust-num { font-family: var(--display); font-size: 1.6rem; color: var(--gold); letter-spacing: 0.05em; }
    .trust-lbl { font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); }
    .trust-sep { color: var(--dim); font-size: 1.2rem; flex-shrink: 0; }

    /* ── GALLERY 1 — ASYMMETRIC ── */
    .gallery-asym {
      display: grid;
      grid-template-columns: 1.6fr 1fr 1fr;
      grid-template-rows: 240px 240px;
      gap: 4px;
    }
    .gallery-asym .g-main { grid-row: 1 / 3; }
    .gallery-asym img {
      height: 100%;
      filter: brightness(0.75) saturate(0.65);
      transition: filter 0.4s, transform 0.5s;
    }
    .gallery-asym img:hover { filter: brightness(0.95) saturate(0.9); transform: scale(1.02); }
    @media (max-width: 768px) {
      .gallery-asym { grid-template-columns: 1fr 1fr; grid-template-rows: 180px 180px; }
      .gallery-asym .g-main { grid-row: auto; }
    }

    /* ── PAS ── */
    .pas { background: var(--bg2); border-top: 1px solid var(--border); }
    .pas-grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: 0; }
    .pas-img-wrap { position: relative; overflow: hidden; }
    .pas-img-wrap img { height: 100%; min-height: 560px; filter: brightness(0.7) saturate(0.6); }
    .pas-img-wrap::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(to right, transparent 70%, var(--bg2) 100%);
    }
    .pas-text {
      padding: 5rem 3.5rem;
      display: flex; flex-direction: column; justify-content: center;
    }
    .pas-text .overline { margin-bottom: 1.25rem; }
    .pas-text h2 { font-size: clamp(1.8rem, 3vw, 2.6rem); margin-bottom: 1.75rem; }
    .pas-text p { color: var(--muted); margin-bottom: 1rem; line-height: 1.85; font-size: 0.95rem; }
    .pas-pull {
      border-left: 2px solid var(--gold);
      padding-left: 1.25rem;
      margin-top: 1.5rem;
      color: var(--cream);
      font-family: var(--serif);
      font-style: italic;
      font-size: 1.05rem;
      line-height: 1.6;
    }
    @media (max-width: 768px) {
      .pas-grid { grid-template-columns: 1fr; }
      .pas-img-wrap { display: none; }
      .pas-text { padding: 4rem 2rem; }
    }

    /* ── ABOUT ── */
    .about { position: relative; overflow: hidden; text-align: center; }
    .about-bg-text {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
      font-family: var(--display);
      font-size: clamp(80px, 18vw, 200px);
      color: rgba(200,164,74,0.04);
      white-space: nowrap; pointer-events: none; letter-spacing: 0.05em;
      user-select: none;
    }
    .about-inner { position: relative; max-width: 640px; margin: 0 auto; }
    .about-inner .overline { margin-bottom: 1.25rem; }
    .about-inner h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); margin-bottom: 1.75rem; }
    .about-inner p { color: var(--muted); line-height: 1.85; margin-bottom: 0.85rem; font-size: 0.95rem; }

    /* ── SERVICES ── */
    .services { background: var(--bg2); }
    .services-head { text-align: center; margin-bottom: 5rem; }
    .services-head h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); }

    .cat-block {
      position: relative;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      margin-bottom: 1px;
      overflow: hidden;
    }
    .cat-block.flip { direction: rtl; }
    .cat-block.flip > * { direction: ltr; }

    .cat-img-wrap { position: relative; overflow: hidden; }
    .cat-img-wrap img {
      height: 500px;
      filter: brightness(0.72) saturate(0.65);
      transition: filter 0.5s, transform 0.6s;
    }
    .cat-img-wrap:hover img { filter: brightness(0.9) saturate(0.8); transform: scale(1.04); }
    .cat-chip {
      position: absolute; top: 1.5rem; left: 1.5rem;
      background: rgba(8,8,7,0.85);
      border: 1px solid var(--border);
      padding: 0.3rem 0.75rem;
      font-size: 0.6rem; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--gold);
    }

    .cat-text {
      padding: 4rem 3.5rem;
      display: flex; flex-direction: column; justify-content: center;
      position: relative;
    }
    .cat-watermark {
      position: absolute;
      top: 1rem; left: 2rem;
      font-family: var(--display);
      font-size: clamp(60px, 10vw, 120px);
      color: rgba(200,164,74,0.05);
      pointer-events: none; user-select: none;
      letter-spacing: 0.05em; line-height: 1;
    }
    .cat-text h3 {
      font-family: var(--display);
      font-size: clamp(2rem, 4vw, 3rem);
      letter-spacing: 0.06em;
      margin-bottom: 0.25rem;
    }
    .cat-text .cat-desc { color: var(--muted); font-size: 0.88rem; margin-bottom: 2rem; }

    .price-list { list-style: none; }
    .price-row {
      display: flex; align-items: baseline;
      padding: 0.6rem 0;
      border-bottom: 1px solid rgba(200,164,74,0.07);
    }
    .price-row:last-of-type { border-bottom: none; }
    .price-name { font-size: 0.85rem; font-weight: 400; flex-shrink: 0; }
    .price-sub { font-size: 0.68rem; color: var(--muted); margin-left: 0.4rem; flex-shrink: 0; }
    .price-dots {
      flex: 1;
      border-bottom: 1px dotted rgba(200,164,74,0.25);
      margin: 0 0.6rem 0.2rem;
      min-width: 1rem;
    }
    .price-val { font-family: var(--serif); font-size: 1.05rem; color: var(--gold); flex-shrink: 0; }
    .cat-cta { margin-top: 2rem; }

    @media (max-width: 768px) {
      .cat-block { grid-template-columns: 1fr; }
      .cat-block.flip { direction: ltr; }
      .cat-img-wrap img { height: 260px; }
      .cat-text { padding: 3rem 2rem; }
    }

    /* ── GALLERY 2 — THE WORK ── */
    .work { background: var(--bg3); }
    .work-head { text-align: center; padding-bottom: 3rem; }
    .work-head h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); margin-top: 0.75rem; }
    .work-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px; }

    .work-item { position: relative; overflow: hidden; }
    .work-item img {
      height: 280px; width: 100%;
      filter: brightness(0.72) saturate(0.6);
      transition: filter 0.4s var(--ease), transform 0.55s var(--ease);
    }
    .work-item:hover img { filter: brightness(0.45) saturate(0.5); transform: scale(1.05); }
    .work-overlay {
      position: absolute; inset: 0;
      display: flex; align-items: flex-end; padding: 1.5rem;
      opacity: 0; transition: opacity 0.4s var(--ease);
    }
    .work-item:hover .work-overlay { opacity: 1; }
    .work-overlay span {
      font-family: var(--display);
      font-size: 1.05rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--cream);
      border-bottom: 1px solid var(--gold);
      padding-bottom: 0.3rem;
    }

    @media (max-width: 768px) {
      .work-grid { grid-template-columns: repeat(2, 1fr); }
      .work-item img { height: 180px; }
      .work-overlay { opacity: 1; }
    }

    /* ── REVIEWS ── */
    .reviews-head { text-align: center; margin-bottom: 3rem; }
    .reviews-stars { font-size: 1.5rem; color: var(--gold); margin-bottom: 0.75rem; }
    .reviews-head h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); }
    .reviews-head p { color: var(--muted); margin-top: 0.5rem; font-size: 0.9rem; }

    .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; }
    .review-card {
      background: var(--bg2);
      padding: 2rem;
      border-top: 2px solid transparent;
      transition: border-color 0.3s;
      position: relative;
    }
    .review-card:hover { border-top-color: var(--gold); }
    .r-stars { font-size: 0.8rem; color: var(--gold); margin-bottom: 1.25rem; }
    .r-text {
      font-family: var(--serif); font-style: italic;
      font-size: 1.05rem; color: var(--cream);
      line-height: 1.7; margin-bottom: 1.5rem;
    }
    .r-client {
      display: flex; align-items: center; gap: 0.85rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--border);
    }
    .r-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: var(--gold-dim); border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--serif); font-size: 0.82rem; color: var(--gold); flex-shrink: 0;
    }
    .r-name { font-size: 0.82rem; font-weight: 500; letter-spacing: 0.04em; }
    .r-date { font-size: 0.65rem; letter-spacing: 0.08em; color: var(--muted); margin-top: 0.15rem; }

    @media (max-width: 768px) { .reviews-grid { grid-template-columns: 1fr; } }

    /* ── LOCATION ── */
    .location { background: var(--bg2); border-top: 1px solid var(--border); }
    .location-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: start; }
    .loc-h { margin-bottom: 2.5rem; }
    .loc-h h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); line-height: 1.1; }
    .loc-address { color: var(--muted); font-size: 0.88rem; line-height: 2; margin-bottom: 2rem; }
    .loc-address strong { color: var(--cream); display: block; margin-bottom: 0.1rem; }
    .hours-table { width: 100%; border-collapse: collapse; margin-bottom: 2.5rem; }
    .hours-table tr { border-bottom: 1px solid rgba(200,164,74,0.07); }
    .hours-table tr:last-child { border-bottom: none; }
    .hours-table td { padding: 0.7rem 0; font-size: 0.85rem; }
    .hours-table td:first-child { color: var(--muted); }
    .hours-table td:last-child { text-align: right; font-weight: 500; }
    .loc-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

    .map-panel {
      height: 420px;
      border: 1px solid var(--border);
      overflow: hidden;
      position: relative;
    }
    .map-panel iframe {
      width: 100%; height: 100%; border: 0;
      filter: invert(92%) hue-rotate(180deg) saturate(0.65) brightness(0.88);
    }

    @media (max-width: 768px) {
      .location-grid { grid-template-columns: 1fr; gap: 3rem; }
      .map-panel { height: 280px; }
    }

    /* ── FINAL CTA ── */
    .final { text-align: center; border-top: 1px solid var(--border); position: relative; overflow: hidden; }
    .final::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at center bottom, rgba(200,164,74,0.06) 0%, transparent 65%);
    }
    .final-inner { position: relative; max-width: 600px; margin: 0 auto; }
    .final-inner h2 { font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 1rem; }
    .final-inner p { color: var(--muted); margin-bottom: 3rem; font-size: 1rem; }
    .steps { display: flex; justify-content: center; gap: 3rem; margin-bottom: 3rem; flex-wrap: wrap; }
    .step-item { display: flex; flex-direction: column; align-items: center; gap: 0.6rem; }
    .step-num {
      width: 2.5rem; height: 2.5rem; border-radius: 50%;
      border: 1px solid var(--gold);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--serif); font-size: 1rem; color: var(--gold);
    }
    .step-lbl { font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); }

    /* ── FOOTER ── */
    footer { background: var(--bg); border-top: 1px solid var(--border); padding: 4.5rem 0 2rem; }
    .footer-grid {
      display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 4rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 2rem;
    }
    .footer-brand-logo { font-family: var(--display); font-size: 1.2rem; letter-spacing: 0.1em; margin-bottom: 0.75rem; }
    .footer-brand-logo em { color: var(--gold); font-style: normal; }
    .footer-tagline { font-size: 0.85rem; color: var(--muted); line-height: 1.75; max-width: 260px; margin-bottom: 1.5rem; }
    .footer-social {
      display: inline-flex; align-items: center; gap: 0.6rem;
      font-size: 0.7rem; letter-spacing: 0.12em; color: var(--muted);
      transition: color 0.2s;
    }
    .footer-social:hover { color: var(--gold); }
    .footer-col-title {
      font-size: 0.6rem; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--gold); font-weight: 500; margin-bottom: 1.25rem;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
    .footer-col a {
      font-size: 0.85rem; color: var(--muted);
      transition: color 0.2s, padding-left 0.25s var(--ease);
      display: inline-block;
    }
    .footer-col a:hover { color: var(--cream); padding-left: 0.4rem; }
    .footer-hours { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1rem; }
    .footer-hours div { display: flex; justify-content: space-between; font-size: 0.8rem; color: var(--muted); }
    .footer-hours span { color: var(--cream); }
    .footer-bottom { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
    .footer-copy { font-size: 0.65rem; color: var(--dim); }

    @media (max-width: 768px) {
      .footer-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .footer-bottom { flex-direction: column; text-align: center; }
    }
    @media (max-width: 600px) { .footer-bottom { flex-direction: column; text-align: center; } }
  </style>
